generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["config", "consolidado", "ctacte", "public", "sbs"]
}

model TipoUsuario {
  id       Int               @id @default(autoincrement())
  nombre   String            @unique
  permisos PermisoPantalla[]
  usuarios Usuario[]

  @@schema("config")
}

model OpcionMenu {
  id       Int               @id @default(autoincrement())
  nombre   String
  ruta     String
  icono    String?
  orden    Int?              @default(0)
  grupo    GrupoMenu?
  permisos PermisoPantalla[]

  @@schema("config")
}

model PermisoPantalla {
  id            Int         @id @default(autoincrement())
  tipoUsuarioId Int
  opcionMenuId  Int
  opcionMenu    OpcionMenu  @relation(fields: [opcionMenuId], references: [id], onDelete: Cascade)
  tipoUsuario   TipoUsuario @relation(fields: [tipoUsuarioId], references: [id], onDelete: Cascade)

  @@unique([tipoUsuarioId, opcionMenuId])
  @@schema("config")
}

model Usuario {
  id            Int         @id @default(autoincrement())
  nombre        String
  email         String      @unique
  password      String
  tipoUsuarioId Int
  tipoUsuario   TipoUsuario @relation(fields: [tipoUsuarioId], references: [id])

  @@schema("config")
}

model calendario_periodos {
  periodo String    @id @db.VarChar(6)
  fecha   DateTime? @db.Date
  tc      Decimal?  @db.Decimal
  activo  Boolean   @default(false)

  @@schema("consolidado")
}

model carterasdpf {
  per           String    @db.VarChar(6)
  idcdp         String    @db.VarChar(28)
  idsocio       String?   @db.VarChar(25)
